<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.srt.kg.mapper.IndustryMapper">
    <select id="findAll" resultType="com.srt.kg.entity.Industry">
        SELECT * FROM industry ORDER BY hotness_score DESC
    </select>
    <select id="findById" resultType="com.srt.kg.entity.Industry">
        SELECT * FROM industry WHERE id = #{id}
    </select>
    <select id="findByName" resultType="com.srt.kg.entity.Industry">
        SELECT * FROM industry WHERE name = #{name}
    </select>
    <insert id="insert" parameterType="com.srt.kg.entity.Industry" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO industry(name, policy_date, hotness_score) VALUES(#{name}, #{policyDate}, #{hotnessScore})
    </insert>
</mapper>
